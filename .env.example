# Copy to .env (gitignored) and fill in. Used by scripts/substack-post.mjs.
#
# SUBSTACK_SID: session cookie for the logged-in Substack account.
#   Get it: log in at substack.com → DevTools → Application → Cookies →
#   https://substack.com → copy the value of `substack.sid`.
#   It is a full session credential — treat like a password. It invalidates
#   when you log out of that browser session.
SUBSTACK_SID=

# Optional: set only if `substack-post.mjs probe` can't auto-resolve it.
SUBSTACK_USER_ID=
