---
interface Props {
  href: string;
  title: string;
  excerpt: string;
  client?: string;
}

const { href, title, excerpt, client } = Astro.props;
---

<article
  class="group p-6 rounded-lg border border-divider/60 bg-surface/40 hover:bg-surface/70 transition-colors h-full flex flex-col"
>
  {client && (
    <p class="text-xs uppercase tracking-wide text-muted mb-3">{client}</p>
  )}
  <h3
    class="text-xl font-semibold tracking-tight text-fg mb-3 group-hover:text-accent transition-colors"
  >
    <a href={href}>{title}</a>
  </h3>
  <p class="text-muted leading-relaxed flex-1">{excerpt}</p>
  <p class="mt-4 text-sm text-accent opacity-0 group-hover:opacity-100 transition-opacity">
    Read the study →
  </p>
</article>
