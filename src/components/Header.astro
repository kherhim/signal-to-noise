---
const pathname = Astro.url.pathname;
const links = [
  { href: '/insights', label: 'Insights' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href: string) =>
  pathname === href || pathname === href + '/' || pathname.startsWith(href + '/');
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-canvas/80 border-b border-divider/60">
  <nav class="mx-auto max-w-[1100px] px-6 h-16 flex items-center justify-between">
    <a
      href="/"
      class="font-semibold tracking-tight text-fg hover:text-accent transition-colors"
    >
      Home
    </a>
    <ul class="flex items-center gap-4 sm:gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'font-semibold tracking-tight transition-colors',
              isActive(href) ? 'text-accent' : 'text-fg hover:text-accent',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
