---
const headline = 'I find the signal where most people see noise.';
const words = headline.split(' ');
---

<section class="relative overflow-hidden">
  <div class="hero-glow" aria-hidden="true"></div>

  <div
    class="relative z-10 mx-auto max-w-[1100px] px-6 pt-20 pb-20 sm:pt-32 sm:pb-28"
  >
    <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_1fr] gap-12 lg:gap-16 items-center">
      {/* Text column */}
      <div>
        <p class="text-sm uppercase tracking-widest text-accent mb-6">Signal, not noise.</p>

        <h1
          class="text-5xl sm:text-7xl font-semibold tracking-tight leading-[1.05] text-fg max-w-3xl"
        >
          {words.map((word, i) => (
            <Fragment>
              <span class="hero-word" style={`--word-i: ${i};`}>{word}</span>{i < words.length - 1 ? ' ' : ''}
            </Fragment>
          ))}
        </h1>

        {/* Descriptive H2 — anchors the page topically for both readers
           and search. Sized below H1, in muted weight, so the hierarchy
           still reads H1 → tagline → intro paragraph. */}
        <h2
          class="mt-6 text-xl sm:text-2xl font-medium tracking-tight text-muted max-w-2xl hero-fade"
          style="--delay: 500ms;"
        >
          Pragmatic essays on finance, AI, and capital strategy — for CFOs, finance leaders, and operators.
        </h2>

        <p
          class="mt-8 text-lg sm:text-xl text-muted max-w-2xl leading-relaxed hero-fade"
          style="--delay: 700ms;"
        >
          A strategist and pragmatist working across finance, technology, digital assets,
          and trading. More interested in what actually works than in what the textbook
          says — and in the patterns most readers miss.
        </p>

        <div class="mt-12 flex flex-wrap gap-4 hero-fade" style="--delay: 900ms;">
          <a
            href="/insights"
            class="inline-flex items-center px-5 py-3 rounded-md bg-accent text-canvas font-medium hover:shadow-[0_0_28px_rgba(255,255,255,0.3)] transition-all duration-300"
          >
            Read the insights →
          </a>
        </div>
      </div>

      {/* Orbital — live solar system, steady identity mark. The eight planets
         drawn where they actually are today (JPL Keplerian elements), advancing
         at ~3 sim-days per second: Mercury laps in ~30 s, the outer planets
         barely drift. True planet colors, unlabeled — it reads as an orbital
         glyph first and rewards anyone who looks closer. */}
      <div class="galaxy-wrap hero-fade" style="--delay: 300ms;">
        <canvas class="solar" width="420" height="420" aria-hidden="true"></canvas>
      </div>
    </div>
  </div>
</section>

<script>
  // Hero solar system. Positions come from JPL's approximate Keplerian
  // elements (Standish table, valid 1800–2050) evaluated at the real
  // current date — the planets are where they actually are right now.
  // Distances are log-compressed so Mercury–Neptune fit one canvas.
  // Each entry: el = [a AU, e, I°, L°, long.peri°, long.node°],
  // rate = change per Julian century, dot = drawn radius at 420 px,
  // color = the planet's real hue, muted to sit on the dark canvas.
  const PLANETS = [
    { el: [0.38709927, 0.20563593, 7.00497902, 252.25032350, 77.45779628, 48.33076593],
      rate: [0.00000037, 0.00001906, -0.00594749, 149472.67411175, 0.16047689, -0.12534081], dot: 1.7, color: '#b5a48f' },
    { el: [0.72333566, 0.00677672, 3.39467605, 181.97909950, 131.60246718, 76.67984255],
      rate: [0.00000390, -0.00004107, -0.00078890, 58517.81538729, 0.00268329, -0.27769418], dot: 2.7, color: '#e8c98a' },
    { el: [1.00000261, 0.01671123, -0.00001531, 100.46457166, 102.93768193, 0.0],
      rate: [0.00000562, -0.00004392, -0.01294668, 35999.37244981, 0.32327364, 0.0], dot: 2.9, color: '#5d9ee0' },
    { el: [1.52371034, 0.09339410, 1.84969142, -4.55343205, -23.94362959, 49.55953891],
      rate: [0.00001847, 0.00007882, -0.00813131, 19140.30268499, 0.44441088, -0.29257343], dot: 2.2, color: '#d96f43' },
    { el: [5.20288700, 0.04838624, 1.30439695, 34.39644051, 14.72847983, 100.47390909],
      rate: [-0.00011607, -0.00013253, -0.00183714, 3034.74612775, 0.21252668, 0.20469106], dot: 5.6, color: '#d9a878' },
    { el: [9.53667594, 0.05386179, 2.48599187, 49.95424423, 92.59887831, 113.66242448],
      rate: [-0.00125060, -0.00050991, 0.00193609, 1222.49362201, -0.41897216, -0.28867794], dot: 4.9, color: '#e3cf9b', ring: true },
    { el: [19.18916464, 0.04725744, 0.77263783, 313.23810451, 170.95427630, 74.01692503],
      rate: [-0.00196176, -0.00004397, -0.00242939, 428.48202785, 0.40805281, 0.04240589], dot: 3.6, color: '#9fd6dd' },
    { el: [30.06992276, 0.00859048, 1.77004347, -55.12002969, 44.96476227, 131.78422574],
      rate: [0.00026291, 0.00005105, 0.00035372, 218.45945325, -0.32241464, -0.00508664], dot: 3.5, color: '#5274d6' },
  ];

  const DEG = Math.PI / 180;
  const SIM_DAYS_PER_SEC = 3; // Mercury laps in ~29 s — same cadence as the old 28 s triangle

  function keplerE(M: number, e: number) {
    M = ((M % (2 * Math.PI)) + 3 * Math.PI) % (2 * Math.PI) - Math.PI;
    let E = M;
    for (let i = 0; i < 8; i++) E -= (E - e * Math.sin(E) - M) / (1 - e * Math.cos(E));
    return E;
  }

  // Heliocentric ecliptic [x, y] in AU (top-down view; z dropped)
  function helioPos(p: (typeof PLANETS)[number], jd: number) {
    const T = (jd - 2451545.0) / 36525;
    const a = p.el[0] + p.rate[0] * T, e = p.el[1] + p.rate[1] * T, I = (p.el[2] + p.rate[2] * T) * DEG;
    const L = (p.el[3] + p.rate[3] * T) * DEG, lp = (p.el[4] + p.rate[4] * T) * DEG, node = (p.el[5] + p.rate[5] * T) * DEG;
    const w = lp - node;
    const E = keplerE(L - lp, e);
    const xp = a * (Math.cos(E) - e), yp = a * Math.sqrt(1 - e * e) * Math.sin(E);
    const cw = Math.cos(w), sw = Math.sin(w), cn = Math.cos(node), sn = Math.sin(node), ci = Math.cos(I);
    return [
      (cw * cn - sw * sn * ci) * xp + (-sw * cn - cw * sn * ci) * yp,
      (cw * sn + sw * cn * ci) * xp + (-sw * sn + cw * cn * ci) * yp,
    ];
  }

  let cleanup: (() => void) | null = null;

  function setupSolar() {
    if (cleanup) { cleanup(); cleanup = null; }
    const canvas = document.querySelector<HTMLCanvasElement>('canvas.solar');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const jd0 = Date.now() / 86400000 + 2440587.5;
    const t0 = performance.now();
    let W = 0, scale = 1, paths: Path2D[] = [];
    let raf = 0, running = false, visible = true;

    // log-compress heliocentric distance; linear inside Mercury's orbit
    function rPx(rAU: number) {
      const minR = W * 0.085, maxR = W * 0.47;
      if (rAU <= 0.387) return (rAU / 0.387) * minR;
      return minR + (Math.log(rAU / 0.387) / Math.log(30.07 / 0.387)) * (maxR - minR);
    }
    function toScreen([x, y]: number[]) {
      const r = Math.hypot(x, y) || 1e-9;
      const s = rPx(r) / r;
      return [W / 2 + x * s, W / 2 - y * s]; // y flipped: orbits run CCW as seen from ecliptic north
    }

    function layout() {
      const dpr = window.devicePixelRatio || 1;
      W = Math.max(1, Math.round(canvas.clientWidth * dpr));
      canvas.width = canvas.height = W;
      scale = W / 420;
      // orbit paths: one analytic period each, sampled through the same projection
      paths = PLANETS.map((p) => {
        const period = 365.25 * Math.pow(p.el[0], 1.5);
        const path = new Path2D();
        for (let i = 0; i <= 120; i++) {
          const [sx, sy] = toScreen(helioPos(p, jd0 + (i / 120) * period));
          i ? path.lineTo(sx, sy) : path.moveTo(sx, sy);
        }
        path.closePath();
        return path;
      });
      draw(jd0 + ((performance.now() - t0) / 1000) * SIM_DAYS_PER_SEC);
    }

    function draw(jd: number) {
      ctx.clearRect(0, 0, W, W);

      ctx.lineWidth = Math.max(0.6, 0.6 * scale);
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.14)';
      for (const path of paths) ctx.stroke(path);

      const cx = W / 2;
      const glow = ctx.createRadialGradient(cx, cx, 0, cx, cx, 46 * scale);
      glow.addColorStop(0, 'rgba(255, 224, 150, 0.75)');
      glow.addColorStop(0.25, 'rgba(255, 190, 90, 0.14)');
      glow.addColorStop(1, 'rgba(255, 170, 60, 0)');
      ctx.fillStyle = glow;
      ctx.beginPath(); ctx.arc(cx, cx, 46 * scale, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#fff3d0';
      ctx.beginPath(); ctx.arc(cx, cx, 5 * scale, 0, Math.PI * 2); ctx.fill();

      ctx.shadowBlur = 7 * scale;
      for (let i = 0; i < PLANETS.length; i++) {
        const p = PLANETS[i];
        const [sx, sy] = toScreen(helioPos(p, jd));
        const r = p.dot * scale;
        ctx.shadowColor = p.color;
        ctx.fillStyle = p.color;
        ctx.beginPath(); ctx.arc(sx, sy, r, 0, Math.PI * 2); ctx.fill();
        if (p.ring) {
          ctx.strokeStyle = 'rgba(227, 207, 155, 0.6)';
          ctx.lineWidth = 0.9 * scale;
          ctx.beginPath(); ctx.ellipse(sx, sy, r * 2.1, r * 0.8, -0.5, 0, Math.PI * 2); ctx.stroke();
        }
      }
      ctx.shadowBlur = 0;
    }

    function loop() {
      if (!visible) { running = false; return; }
      draw(jd0 + ((performance.now() - t0) / 1000) * SIM_DAYS_PER_SEC);
      raf = requestAnimationFrame(loop);
    }
    function start() {
      if (running || reduced) return;
      running = true;
      raf = requestAnimationFrame(loop);
    }

    const io = new IntersectionObserver(([entry]) => {
      visible = entry.isIntersecting;
      if (visible) start();
    });
    io.observe(canvas);

    addEventListener('resize', layout);
    layout(); // also draws the static frame reduced-motion users keep
    start();

    cleanup = () => {
      cancelAnimationFrame(raf);
      removeEventListener('resize', layout);
      io.disconnect();
    };
  }

  document.addEventListener('astro:page-load', setupSolar);
</script>
