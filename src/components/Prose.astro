---
/* Wraps MDX content with long-form typography styling.
   Targets the rendered HTML inside the slot via `:global(...)`. */
---

<div class="prose-custom">
  <slot />
</div>

<style>
  .prose-custom {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-fg);
  }

  .prose-custom :global(p) {
    margin-bottom: 1.5em;
  }

  .prose-custom :global(h2) {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    color: var(--color-fg);
  }

  .prose-custom :global(h3) {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-fg);
  }

  .prose-custom :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 150ms ease;
  }

  .prose-custom :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .prose-custom :global(strong) {
    color: var(--color-fg);
    font-weight: 600;
  }

  .prose-custom :global(em) {
    color: var(--color-fg);
  }

  .prose-custom :global(ul),
  .prose-custom :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }

  .prose-custom :global(ul) {
    list-style-type: disc;
  }

  .prose-custom :global(ol) {
    list-style-type: decimal;
  }

  .prose-custom :global(li) {
    margin-bottom: 0.5em;
  }

  .prose-custom :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25em;
    margin: 1.75em 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .prose-custom :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background-color: var(--color-surface);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    color: var(--color-fg);
  }

  .prose-custom :global(pre) {
    font-family: var(--font-mono);
    background-color: var(--color-surface);
    padding: 1.25em;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5em 0;
    border: 1px solid var(--color-divider);
  }

  .prose-custom :global(pre code) {
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: 0.875rem;
  }

  .prose-custom :global(hr) {
    border: none;
    border-top: 1px solid var(--color-divider);
    margin: 3em 0;
  }
</style>
