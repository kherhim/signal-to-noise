---
/* Site-wide deep-space backdrop, rendered on every page.
   A still star field. Brightness follows a rough power law — many
   near-invisible stars, a few bright anchors — which is what makes
   a sky read as deep rather than busy. Flicker is slow and spread
   thinly across all tiers. Nothing here moves: the solar system in
   the Hero is the only motion on the site. Pure SVG + CSS, no JS.
   `heroClear` (home only) masks a soft hole under the hero orbital;
   `dim` (reading pages) lowers the field so long-form text wins. */
interface Props {
  heroClear?: boolean;
  dim?: boolean;
}
const { heroClear = false, dim = false } = Astro.props;

// Seeded PRNG so positions are stable across builds.
function mulberry32(seed: number) {
  return function () {
    seed = (seed + 0x6d2b79f5) | 0;
    let t = seed;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rng = mulberry32(42);
const rand = (min: number, max: number) => min + rng() * (max - min);

/* Weighted star-color palette — realistic stellar classification:
   sky-blue cool end, neutral whites, warm yellows/oranges/reds.
   No purple — the cool end leans cyan/sky, like real starlight. */
const palette = [
  { hex: '#f8fafc', w: 28 }, // slate-50 — cool white (common)
  { hex: '#ffffff', w: 18 }, // pure white
  { hex: '#cffafe', w: 16 }, // cyan-100 — cyan-white
  { hex: '#7dd3fc', w: 10 }, // sky-300 — pale sky-blue
  { hex: '#fef9c3', w: 12 }, // yellow-100 — yellow-white
  { hex: '#fed7aa', w: 9 },  // orange-200 — orange tint
  { hex: '#fecaca', w: 7 },  // red-200 — faint red
];
const paletteTotal = palette.reduce((s, p) => s + p.w, 0);

function pickColor(): string {
  let n = rng() * paletteTotal;
  for (const p of palette) {
    if (n < p.w) return p.hex;
    n -= p.w;
  }
  return palette[0].hex;
}

/* Three brightness tiers, power-law-ish: the faint tier carries the
   sense of depth, the bright tier gives the eye a few anchors.
   `twinkle` is the probability a star in that tier twinkles at all —
   every tier flickers a little, brighter tiers more often. */
const TIERS = [
  { n: 80, r: [0.06, 0.16], op: [0.08, 0.28], twinkle: 0.3 },
  { n: 32, r: [0.16, 0.3], op: [0.3, 0.55], twinkle: 0.6 },
  { n: 8, r: [0.32, 0.5], op: [0.7, 0.95], twinkle: 1 },
];

const stars = TIERS.flatMap((tier) =>
  Array.from({ length: tier.n }, () => ({
    x: rand(-10, 110),
    y: rand(-10, 110),
    r: rand(tier.r[0], tier.r[1]),
    opacity: rand(tier.op[0], tier.op[1]),
    color: pickColor(),
    twinkles: rng() < tier.twinkle,
    twinkleDuration: rand(3.5, 9),
    twinkleDelay: -rand(0, 9),
  })),
);
---

<svg
  class:list={['space-bg', heroClear && 'space-bg--hero-clear', dim && 'space-bg--dim']}
  viewBox="0 0 100 100"
  preserveAspectRatio="xMidYMid slice"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    {/* Soft Gaussian glow — gives each star a halo without DOM bloat. */}
    <filter id="star-glow" x="-200%" y="-200%" width="500%" height="500%">
      <feGaussianBlur stdDeviation="0.45" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
    <radialGradient id="galaxy-smudge">
      <stop offset="0%" stop-color="#f8fafc" stop-opacity="1" />
      <stop offset="55%" stop-color="#f8fafc" stop-opacity="0.35" />
      <stop offset="100%" stop-color="#f8fafc" stop-opacity="0" />
    </radialGradient>
  </defs>

  {/* Distant galaxies — static, barely-there smudges that give the
     field a sense of scale beyond the stars. */}
  <ellipse cx="22" cy="28" rx="9" ry="3.2" fill="url(#galaxy-smudge)" opacity="0.06" transform="rotate(-28 22 28)" />
  <ellipse cx="79" cy="70" rx="6.5" ry="2.4" fill="url(#galaxy-smudge)" opacity="0.05" transform="rotate(17 79 70)" />

  <g filter="url(#star-glow)">
    {stars.map((s) => (
      <circle
        class={s.twinkles ? 'space-obj' : undefined}
        cx={s.x.toFixed(3)}
        cy={s.y.toFixed(3)}
        r={s.r.toFixed(3)}
        fill={s.color}
        opacity={s.twinkles ? undefined : s.opacity.toFixed(2)}
        style={
          s.twinkles
            ? `--base-opacity: ${s.opacity.toFixed(2)}; --twinkle-duration: ${s.twinkleDuration.toFixed(2)}s; --twinkle-delay: ${s.twinkleDelay.toFixed(2)}s;`
            : undefined
        }
      />
    ))}
  </g>
</svg>
