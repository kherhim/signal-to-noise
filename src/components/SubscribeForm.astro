---
/* Beehiiv subscribe embed (form id below).
   The form's inner colours (background, text, button) are configured on
   the Beehiiv side: Subscribers → Subscribe forms → this form → style.
   Set them to match the site palette (#0a0a0a canvas, white text, accent
   button) or the embed renders on a white card.

   The Beehiiv v3 loader is a third-party script, and Astro's ClientRouter
   does NOT re-run third-party scripts across view transitions — so the
   form is (re)mounted on every astro:page-load instead of relying on the
   raw <script> tag. Idempotent per element via data-mounted.

   framed (default true): renders the bordered article-end variant that
   matches ShareLinks / Related insights. Pass framed={false} on pages
   that provide their own header (e.g. /subscribe). */
interface Props {
  framed?: boolean;
}

const { framed = true } = Astro.props;
const BEEHIIV_FORM_ID = '4f3eb395-2ead-42eb-aef2-f103d633aa68';
---

<aside
  class:list={[framed && 'mt-16 pt-8 border-t border-divider/60']}
  aria-label="Subscribe to the newsletter"
>
  {framed && (
    <>
      <p class="text-sm uppercase tracking-widest text-muted mb-4">Subscribe</p>
      <p class="text-sm text-muted leading-relaxed mb-5 max-w-[52ch]">
        Field notes on finance, AI, and capital strategy — by email. No
        cadence, no noise; only when there's something worth saying.
      </p>
    </>
  )}
  <div class="beehiiv-form w-full max-w-[480px]" data-beehiiv-form={BEEHIIV_FORM_ID}></div>
</aside>

<script>
  // Mount every Beehiiv embed on the page, and re-mount after each Astro
  // view transition (ClientRouter doesn't re-run third-party scripts).
  function mountBeehiivForms() {
    document
      .querySelectorAll('.beehiiv-form[data-beehiiv-form]')
      .forEach((el) => {
        const node = el as HTMLElement;
        if (node.dataset.mounted) return;
        node.dataset.mounted = 'true';
        const script = document.createElement('script');
        script.async = true;
        script.src = 'https://subscribe-forms.beehiiv.com/v3/loader.js';
        script.setAttribute(
          'data-beehiiv-form',
          node.getAttribute('data-beehiiv-form') as string,
        );
        node.appendChild(script);
      });
  }
  document.addEventListener('astro:page-load', mountBeehiivForms);
</script>
