---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpaceBackground from '../components/SpaceBackground.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /* Home only: clears a patch of the star field under the hero's
     solar system so the orbital sits on dark sky. */
  heroClear?: boolean;
  /* Reading pages: dims the star field so long-form text wins. */
  starsDim?: boolean;
}

const {
  title,
  description = 'Pragmatic essays on finance, AI, and capital strategy from a CFO with 25+ years in the field. Signal, not noise.',
  ogImage,
  heroClear = false,
  starsDim = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage ? new URL(ogImage, Astro.url) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* JS-detection: gates the reveal layer so no-JS users see content. */}
    <script is:inline>document.documentElement.classList.add('js');</script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    {/* Google Search Console — domain verification */}
    <meta name="google-site-verification" content="GcEXfuzwBNbGBMqsmljn2SQDLkcETS34_opqwrPsd_g" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImageURL && <meta property="og:image" content={ogImageURL.toString()} />}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL.toString()} />}

    {/* RSS */}
    <link rel="alternate" type="application/rss+xml" title="signal-to-noise" href="/rss.xml" />

    {/* Fonts: Fraunces (display serif, variable with opsz) + JetBrains
       Mono (code). Body uses the system sans stack — no webfont load. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body class="relative">
    <div class="ambient-bg" aria-hidden="true"></div>
    <div class="grid-bg" aria-hidden="true"></div>
    <SpaceBackground heroClear={heroClear} dim={starsDim} />

    <div class="relative z-10 flex flex-col min-h-screen">
      <Header />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      // Reveal elements with [data-reveal] as they enter the viewport.
      // Re-runs after every view transition via astro:page-load.
      function setupReveal() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('[data-reveal]:not(.is-revealed)');

        if (reduced) {
          els.forEach((el) => el.classList.add('is-revealed'));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -10% 0px' },
        );

        els.forEach((el) => io.observe(el));
      }

      document.addEventListener('astro:page-load', setupReveal);
    </script>
    </body>
</html>
