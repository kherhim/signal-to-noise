---
import BaseLayout from './BaseLayout.astro';
import Prose from '../components/Prose.astro';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags?: string[];
  /* Optional cover image rendered above the header. */
  coverImage?: string;
  coverImageAlt?: string;
  /* Series support — set when this post is part of a multi-part series.
     Kicker text shows above the title (linked to parent for children).
     Parts list renders at the article end for the parent only. */
  seriesKicker?: string;
  seriesKickerHref?: string;
  seriesParts?: { href: string; label: string; part: number }[];
  /* Related insights — 2-3 posts sharing tags with this one, rendered
     at the article end. Computed at the page level. */
  related?: { href: string; title: string; excerpt: string; date: Date }[];
}

const {
  title,
  date,
  excerpt,
  tags = [],
  coverImage,
  coverImageAlt,
  seriesKicker,
  seriesKickerHref,
  seriesParts,
  related = [],
} = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const formatted = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={`${title} — signal-to-noise.co`}
  description={excerpt}
  ogImage={coverImage}
>
  <article class="mx-auto max-w-[720px] px-6 py-16 sm:py-24">
    {coverImage && (
      <figure class="mb-10">
        <img
          src={coverImage}
          alt={coverImageAlt ?? ''}
          loading="eager"
          class="w-full h-auto rounded-lg border border-divider/60"
        />
      </figure>
    )}

    <header class="mb-12">
      {seriesKicker && (
        <p class="text-sm uppercase tracking-widest text-accent mb-6">
          {seriesKickerHref ? (
            <a href={seriesKickerHref} class="hover:underline underline-offset-4">
              {seriesKicker}
            </a>
          ) : (
            seriesKicker
          )}
        </p>
      )}

      <time class="text-sm text-muted block mb-3" datetime={date.toISOString()}>
        {formatted}
      </time>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight leading-tight text-fg">
        {title}
      </h1>
      {tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 mt-6">
          {tags.map((t) => (
            <li>
              <a
                href={`/insights/tag/${t}/`}
                class="inline-block text-xs uppercase tracking-wide text-muted px-2 py-1 border border-divider rounded hover:text-accent hover:border-accent/40 transition-colors"
              >
                {t}
              </a>
            </li>
          ))}
        </ul>
      )}
    </header>

    <Prose>
      <slot />
    </Prose>

    {seriesParts && seriesParts.length > 0 && (
      <section class="mt-16 pt-8 border-t border-divider/60">
        <p class="text-sm uppercase tracking-widest text-muted mb-6">
          The {seriesParts.length} parts
        </p>
        <ol class="space-y-3">
          {seriesParts.map((p) => (
            <li class="flex items-baseline gap-4">
              <span class="text-muted text-xs uppercase tracking-wide w-16 shrink-0">
                Part {p.part}
              </span>
              <a
                href={p.href}
                class="text-fg hover:text-accent transition-colors"
              >
                {p.label}
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    {related.length > 0 && (
      <aside
        class="mt-16 pt-8 border-t border-divider/60"
        aria-labelledby="related-heading"
      >
        <h2
          id="related-heading"
          class="text-sm uppercase tracking-widest text-accent mb-6"
        >
          Related insights
        </h2>
        <ul class="space-y-8">
          {related.map((r) => (
            <li>
              <article class="group">
                <time
                  class="text-xs text-muted block mb-2"
                  datetime={r.date.toISOString()}
                >
                  {fmt(r.date)}
                </time>
                <h3 class="text-lg sm:text-xl font-semibold tracking-tight text-fg mb-2 group-hover:text-accent transition-colors">
                  <a href={r.href}>{r.title}</a>
                </h3>
                <p class="text-sm text-muted leading-relaxed">{r.excerpt}</p>
              </article>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>
</BaseLayout>
