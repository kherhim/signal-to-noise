---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import InsightCard from '../components/InsightCard.astro';

// In dev, show drafts so you can preview them; in prod, drafts stay hidden.
const allInsights = (await getCollection(
  'insights',
  ({ data }) => import.meta.env.DEV || !data.draft,
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Series children don't surface independently on the homepage — they hang
// from their parent on the insights page instead.
const homepageCandidates = allInsights.filter((i) => i.data.series?.part === undefined);

/* Featured pick — three-tier priority:
   1. Fresh: latest article published in the last 7 days (so adding a
      new article and rebuilding always promotes it to the featured slot)
   2. Manual: any article with featured: true in frontmatter
   3. Weekly rotation: deterministic by current week-of-epoch, so the
      featured slot rotates automatically when nothing fresh is around.
   Rotation is computed at build time — to actually rotate weekly, the
   site needs to be rebuilt at least weekly (a cron job can handle this). */
function pickFeatured(candidates: typeof homepageCandidates) {
  if (candidates.length === 0) return undefined;

  const ONE_WEEK = 7 * 24 * 60 * 60 * 1000;
  const oneWeekAgo = Date.now() - ONE_WEEK;
  const fresh = candidates
    .filter((p) => p.data.date.getTime() >= oneWeekAgo)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  if (fresh.length > 0) return fresh[0];

  const explicit = candidates.find((p) => p.data.featured);
  if (explicit) return explicit;

  const weeksSinceEpoch = Math.floor(Date.now() / ONE_WEEK);
  return candidates[weeksSinceEpoch % candidates.length];
}

const featured = pickFeatured(homepageCandidates);
const recent = homepageCandidates.filter((i) => i.id !== featured?.id).slice(0, 3);
---

<BaseLayout title="signal-to-noise.co — Himanshu" stars>
  <Hero />

  {featured && (
    <section class="mx-auto max-w-[1100px] px-6 py-16" data-reveal>
      <p class="text-xs uppercase tracking-widest text-muted mb-6">Featured</p>
      <article class="border-l-2 border-accent pl-6 sm:pl-8 py-2">
        <time
          class="text-sm text-muted block mb-3"
          datetime={featured.data.date.toISOString()}
        >
          {featured.data.date.toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          })}
        </time>
        <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-tight text-fg mb-4">
          <a
            href={`/insights/${featured.id}`}
            class="hover:text-accent transition-colors"
          >
            {featured.data.title}
          </a>
        </h2>
        <p class="text-lg text-muted leading-relaxed max-w-2xl mb-4">
          {featured.data.excerpt}
        </p>
        <a
          href={`/insights/${featured.id}`}
          class="text-sm text-accent hover:text-accent-hover transition-colors"
        >
          Read →
        </a>
      </article>
    </section>
  )}

  {recent.length > 0 && (
    <section class="mx-auto max-w-[1100px] px-6 py-16" data-reveal>
      <div class="flex items-end justify-between mb-8">
        <h2 class="text-2xl font-semibold tracking-tight text-fg">Recent insights</h2>
        <a
          href="/insights"
          class="text-sm text-muted hover:text-accent transition-colors"
        >
          All insights →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recent.map((post) => (
          <InsightCard
            href={`/insights/${post.id}`}
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date}
          />
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-[1100px] px-6 py-16" data-reveal>
    <h2 class="text-2xl font-semibold tracking-tight text-fg mb-8">Reading the noise</h2>
    <div class="max-w-[720px] space-y-6 text-lg text-fg leading-relaxed">
      <p>
        Most finance writing is one of two things: a quarterly earnings rehash, or a hot
        take with no model behind it. The first is data without thinking. The second is
        thinking without data. The space between them — <em>signal</em> — is where I want
        to write.
      </p>
      <p>
        Over 25+ years in finance, I've come to believe the most useful thing a finance
        person does in a fast-moving business isn't reporting — it's <em>framing</em>.
        Cutting a tangled problem down to the two or three decisions that actually matter.
        Translating between a board that wants certainty and an operation where the answer
        hasn't been built yet. Holding the strategic question open while the tactical one
        gets solved.
      </p>
      <p>
        The pieces here are mostly about that work: leadership and trade-offs, storytelling
        for finance, how the CFO role actually operates, how AI is changing it, and the
        recurring tensions — strategy versus execution, output versus outcome, KPIs versus
        mission, decisions versus deferrals.
      </p>
      <p>
        I won't post on a cadence. I'll post when I have something worth saying. That's
        the deal.
      </p>
      <p class="pt-2">
        <a
          href="/about"
          class="text-accent hover:text-accent-hover transition-colors"
        >
          More about me →
        </a>
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1100px] px-6 py-16 mb-12" data-reveal>
    <h2 class="text-2xl font-semibold tracking-tight text-fg mb-6">Get in touch</h2>
    <p class="text-muted mb-6 max-w-[720px]">
      Working on something at the edges of finance and tech? I'd like to hear about it.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/contact"
        class="inline-flex items-center px-5 py-3 rounded-md bg-accent text-canvas font-medium hover:shadow-[0_0_28px_rgba(255,255,255,0.3)] transition-all duration-300"
      >
        Contact →
      </a>
    </div>
  </section>
</BaseLayout>
