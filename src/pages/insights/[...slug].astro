---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getRelatedPosts } from '../../lib/tags';

export async function getStaticPaths() {
  // In dev, generate routes for drafts too; in prod, drafts are excluded.
  const posts = await getCollection(
    'insights',
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

/* Related insights тАФ chosen by tag overlap, then recency. Suppressed for
   series children (their parent + sibling parts are already listed) and
   posts with no tags + no fallback corpus. */
const isSeriesChild = post.data.series?.part !== undefined;
const related = isSeriesChild ? [] : await getRelatedPosts(post, 3);

/* Compute series context for this article (if any).
   - Children get a kicker "Part X of N ┬╖ <Series name>" linked to the parent.
   - Parent gets a kicker "A N-part series" and the parts list at the bottom. */
let seriesKicker: string | undefined;
let seriesKickerHref: string | undefined;
let seriesParts: { href: string; label: string; part: number }[] | undefined;

if (post.data.series) {
  const all = await getCollection(
    'insights',
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  const sid = post.data.series.id;
  const children = all
    .filter((p) => p.data.series?.id === sid && p.data.series.part !== undefined)
    .sort((a, b) => (a.data.series!.part ?? 0) - (b.data.series!.part ?? 0));
  const parent = all.find(
    (p) => p.data.series?.id === sid && p.data.series.part === undefined,
  );

  if (post.data.series.part !== undefined) {
    // Child article
    seriesKicker = `Part ${post.data.series.part} of ${children.length} ┬╖ ${post.data.series.name}`;
    if (parent) seriesKickerHref = `/insights/${parent.id}`;
  } else {
    // Parent article
    seriesKicker = `A ${children.length}-part series`;
    seriesParts = children.map((c) => ({
      href: `/insights/${c.id}`,
      // Strip the "ЁЯУМ N тАФ " prefix from child titles тАФ the "Part N" label already shows the number
      label: c.data.title.replace(/^ЁЯУМ\s*\d+\s*тАФ\s*/, ''),
      part: c.data.series!.part!,
    }));
  }
}
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  excerpt={post.data.excerpt}
  tags={post.data.tags}
  coverImage={post.data.coverImage}
  coverImageAlt={post.data.coverImageAlt}
  seriesKicker={seriesKicker}
  seriesKickerHref={seriesKickerHref}
  seriesParts={seriesParts}
  related={related.map((p) => ({
    href: `/insights/${p.id}`,
    title: p.data.title,
    excerpt: p.data.excerpt,
    date: p.data.date,
  }))}
>
  <Content />
</PostLayout>
