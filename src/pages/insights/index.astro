---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import {
  formatTag,
  getPublishedInsights,
  getTagCounts,
  groupPostsForListing,
} from '../../lib/tags';

const posts = (await getPublishedInsights()).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const items = groupPostsForListing(posts, posts);
const tagCounts = await getTagCounts();
---

<BaseLayout
  title="Insights — Essays on Finance, AI, and Capital Strategy by Himanshu Kher"
  description="Long-form essays on the CFO function, AI in finance, capital structure, and the patterns that show up across trading, fintech, and digital assets."
>
  <section class="mx-auto max-w-[720px] px-6 py-16 sm:py-24">
    <header class="mb-16" data-reveal>
      <p class="text-sm uppercase tracking-widest text-accent mb-6">Insights</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight leading-tight text-fg mb-6">
        Things I've been thinking about.
      </h1>
      <p class="text-lg text-muted leading-relaxed">
        Short takes when there's a sharp point. Longer pieces when there's a real model
        worth showing.
      </p>
    </header>

    {tagCounts.length > 0 && (
      <nav class="mb-16" aria-label="Browse by topic">
        <h2 class="text-sm uppercase tracking-widest text-accent mb-4">
          Browse by topic
        </h2>
        <ul class="flex flex-wrap gap-2">
          {tagCounts.map(({ tag, count }) => (
            <li>
              <a
                href={`/insights/tag/${tag}/`}
                class="inline-flex items-baseline gap-1.5 px-3 py-1.5 border border-divider rounded text-sm text-fg hover:text-accent hover:border-accent/40 transition-colors"
              >
                <span>{formatTag(tag)}</span>
                <span class="text-xs text-muted">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <PostList items={items} />
  </section>
</BaseLayout>
