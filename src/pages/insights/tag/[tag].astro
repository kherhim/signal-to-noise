---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostList from '../../../components/PostList.astro';
import {
  formatTag,
  getPublishedInsights,
  getTagCounts,
  groupPostsForListing,
} from '../../../lib/tags';

export async function getStaticPaths() {
  const counts = await getTagCounts();
  const all = await getPublishedInsights();
  return counts.map(({ tag }) => {
    // Any post that carries the tag OR is the parent of a series whose
    // child carries the tag — so the series parent is included as a
    // header even when only its children match.
    const directMatches = all.filter((p) => p.data.tags?.includes(tag));
    const childSeriesIds = new Set(
      directMatches
        .filter((p) => p.data.series?.part !== undefined)
        .map((p) => p.data.series!.id),
    );
    const seriesParents = all.filter(
      (p) =>
        p.data.series?.id &&
        p.data.series.part === undefined &&
        childSeriesIds.has(p.data.series.id),
    );

    const matchSet = new Set([
      ...directMatches.map((p) => p.id),
      ...seriesParents.map((p) => p.id),
    ]);
    const posts = all
      .filter((p) => matchSet.has(p.id))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { tag },
      props: { tag, posts, all },
    };
  });
}

const { tag, posts, all } = Astro.props;
const label = formatTag(tag);
const items = groupPostsForListing(posts, all);
// "Posts on this topic" count excludes series parents that were pulled
// in only for context (they don't themselves carry the tag).
const directCount = posts.filter((p) => p.data.tags?.includes(tag)).length;
---

<BaseLayout
  title={`${label} — essays on signal-to-noise.co`}
  description={`Every essay on signal-to-noise.co tagged ${label}. ${directCount} ${directCount === 1 ? 'piece' : 'pieces'} from Himanshu Kher.`}
>
  <section class="mx-auto max-w-[720px] px-6 py-16 sm:py-24">
    <header class="mb-16" data-reveal>
      <p class="text-sm uppercase tracking-widest text-accent mb-6">
        <a href="/insights" class="hover:underline underline-offset-4">Insights</a>
        <span class="text-muted px-2">/</span>
        <span>Topic</span>
      </p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight leading-tight text-fg mb-6">
        {label}
      </h1>
      <p class="text-lg text-muted leading-relaxed">
        {directCount === 1
          ? 'One essay on this topic.'
          : `${directCount} essays on this topic.`}
      </p>
    </header>

    <PostList items={items} highlightTag={tag} />

    <footer class="mt-16 pt-8 border-t border-divider/60">
      <a
        href="/insights"
        class="text-accent hover:text-accent-hover transition-colors"
      >
        ← All insights
      </a>
    </footer>
  </section>
</BaseLayout>
