---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOPICS, resolveTopicPosts } from '../../lib/topics';

export async function getStaticPaths() {
  return Promise.all(
    TOPICS.map(async (topic) => {
      const cornerstones = await resolveTopicPosts(topic.cornerstoneSlugs);
      const further = await resolveTopicPosts(topic.furtherSlugs);
      return {
        params: { topic: topic.slug },
        props: { topic, cornerstones, further },
      };
    }),
  );
}

const { topic, cornerstones, further } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`${topic.title} — signal-to-noise.co`}
  description={topic.description}
  ogImage={cornerstones[0]?.data.coverImage}
>
  <section class="mx-auto max-w-[720px] px-6 py-16 sm:py-24">
    <header class="mb-16" data-reveal>
      <p class="text-sm uppercase tracking-widest text-accent mb-6">
        <a href="/topics" class="hover:underline underline-offset-4">Topics</a>
      </p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight leading-tight text-fg mb-6">
        {topic.title}
      </h1>
      <p class="text-lg text-muted leading-relaxed">
        {topic.framing}
      </p>
    </header>

    {cornerstones.length > 0 && (
      <section class="mb-20" aria-labelledby="cornerstones-heading">
        <h2
          id="cornerstones-heading"
          class="text-sm uppercase tracking-widest text-accent mb-8"
        >
          Start here
        </h2>
        <ul class="space-y-12">
          {cornerstones.map((post) => (
            <li>
              <article class="group">
                {post.data.coverImage && (
                  <a href={`/insights/${post.id}`} class="block mb-6">
                    <img
                      src={post.data.coverImage}
                      alt={post.data.coverImageAlt ?? ''}
                      loading="lazy"
                      class="w-full h-auto rounded-lg border border-divider/60 group-hover:border-accent/40 transition-colors"
                    />
                  </a>
                )}
                <time
                  class="text-sm text-muted block mb-2"
                  datetime={post.data.date.toISOString()}
                >
                  {fmt(post.data.date)}
                </time>
                <h3 class="text-2xl sm:text-3xl font-semibold tracking-tight text-fg mb-3 group-hover:text-accent transition-colors">
                  <a href={`/insights/${post.id}`}>{post.data.title}</a>
                </h3>
                <p class="text-muted leading-relaxed">{post.data.excerpt}</p>
              </article>
            </li>
          ))}
        </ul>
      </section>
    )}

    {further.length > 0 && (
      <section class="mb-16" aria-labelledby="further-heading">
        <h2
          id="further-heading"
          class="text-sm uppercase tracking-widest text-accent mb-8"
        >
          Further reading
        </h2>
        <ul class="space-y-8">
          {further.map((post) => (
            <li>
              <article class="group">
                <time
                  class="text-xs text-muted block mb-2"
                  datetime={post.data.date.toISOString()}
                >
                  {fmt(post.data.date)}
                </time>
                <h3 class="text-lg sm:text-xl font-semibold tracking-tight text-fg mb-2 group-hover:text-accent transition-colors">
                  <a href={`/insights/${post.id}`}>{post.data.title}</a>
                </h3>
                <p class="text-sm text-muted leading-relaxed">{post.data.excerpt}</p>
              </article>
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="mt-16 pt-8 border-t border-divider/60 flex items-center justify-between">
      <a
        href="/topics"
        class="text-accent hover:text-accent-hover transition-colors"
      >
        ← All topics
      </a>
      <a
        href="/insights"
        class="text-muted hover:text-accent transition-colors text-sm"
      >
        Full archive →
      </a>
    </footer>
  </section>
</BaseLayout>
